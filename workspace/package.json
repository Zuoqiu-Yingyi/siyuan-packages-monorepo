{
    "name": "workspace",
    "type": "module",
    "private": true,
    "packageManager": "pnpm@11.9.0",
    "author": {
        "name": "Zuoqiu Yingyi",
        "url": "https://github.com/Zuoqiu-Yingyi"
    },
    "license": "AGPL-3.0-or-later",
    "repository": "https://github.com/Zuoqiu-Yingyi/siyuan-plugins-dev",
    "scripts": {
        "submodule:batch": "nu ./../scripts/git-submodule/batch.nu",
        "submodule:update": "git submodule update --init --recursive",
        "prepare": "cd ./.. && husky ./workspace/.husky",
        "lint-staged": "lint-staged --allow-empty",
        "outdated:all": "nu ./scripts/outdated.nu",
        "update:all": "nu ./scripts/update.nu",
        "prune:all": "nu ./scripts/prune.nu",
        "build": "turbo run build",
        "build:dev": "turbo run build:dev",
        "dev": "turbo run dev",
        "lint": "turbo run lint",
        "format": "turbo run format"
    },
    "dependencies": {
        "@siyuan-community/siyuan-sdk": "^0.3.17",
        "@workspace/eslint-config-custom": "workspace:*",
        "@workspace/tsconfig": "workspace:*",
        "@workspace/types": "workspace:*",
        "siyuan": "^1.2.2"
    },
    "devDependencies": {
        "@arco-design/web-vue": "^2.58.0",
        "@arco-plugins/vite-vue": "^1.4.6",
        "@sveltejs/vite-plugin-svelte": "^7.1.2",
        "@tsconfig/svelte": "^5.0.8",
        "@types/node": "^26.1.0",
        "@vitejs/plugin-vue": "^6.0.7",
        "deepmerge": "^4.3.1",
        "eslint": "^10.6.0",
        "husky": "^9.1.7",
        "less": "^4.6.7",
        "lint-staged": "^17.0.8",
        "npm-run-all": "^4.1.5",
        "prettier": "^3.9.4",
        "svelte": "^5.56.4",
        "svelte-check": "^4.7.1",
        "svelte-preprocess": "^6.0.5",
        "tslib": "^2.8.1",
        "tsx": "^4.22.5",
        "turbo": "^2.10.2",
        "typescript": "^6.0.3",
        "vite": "^8.1.3",
        "vite-plugin-static-copy": "^4.1.1",
        "vue": "^3.5.39",
        "vue-i18n": "^11.4.6"
    }
}
